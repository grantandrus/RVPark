@page
@model RVPark.Pages.Profile.VehicleModel
@{
    ViewData["Title"] = "Set Vehicle";
}

<div class="app-container">

    <div class="main-content">

        <div class="profile-container card p-4 shadow-sm">

            <h4 class="text-center mb-3">Vehicle Information</h4>

            <form method="post">

                <div class="form-group mb-3">
                    <label asp-for="Vehicle.Make"></label>
                    <input asp-for="Vehicle.Make" class="form-control" />
                    <span asp-validation-for="Vehicle.Make" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Vehicle.Model"></label>
                    <input asp-for="Vehicle.Model" class="form-control" />
                    <span asp-validation-for="Vehicle.Model" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Vehicle.Year"></label>
                    <input asp-for="Vehicle.Year" type="number" class="form-control" />
                    <span asp-validation-for="Vehicle.Year" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Vehicle.LicensePlate"></label>
                    <input asp-for="Vehicle.LicensePlate" class="form-control" />
                    <span asp-validation-for="Vehicle.LicensePlate" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Vehicle.Color"></label>
                    <input asp-for="Vehicle.Color" class="form-control" />
                    <span asp-validation-for="Vehicle.Color" class="text-danger"></span>
                </div>

                
                <button type="submit" class="btn btn-success">Save Vehicle</button>
                <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
                

            </form>

        </div>

    </div>

</div>