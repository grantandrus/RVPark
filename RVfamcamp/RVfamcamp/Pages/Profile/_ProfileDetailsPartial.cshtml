@model RVPark.Models.ProfileViewModel

<div class="profile-details">
    <p><strong>Name:</strong> @Model.FirstName @Model.LastName</p>
    <p><strong>Email:</strong> @Model.Email</p>
    <p><strong>Phone:</strong> @Model.Phone</p>
    <p><strong>Date of Birth:</strong> @(Model.DateOfBirth?.ToString("yyyy-MM-dd") ?? "N/A")</p>
    <p><strong>Member Since:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd")</p>
</div>